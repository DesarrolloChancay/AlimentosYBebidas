# Archivo: .env.example
# Copia este archivo como .env y configura tus valores locales

# Entorno de ejecución (development/production)
FLASK_ENV=development

# Clave secreta para sesiones de Flask
SECRET_KEY=tu_clave_secreta_muy_segura_aqui

# Configuración de base de datos MySQL
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alimentosybebidas

# Ajustes recomendados para producción detrás de Nginx
TRUST_PROXY_COUNT=1
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH_MB=25

# Restringir Socket.IO al origen real del sistema.
# Ejemplo: https://ayb.clubcastillodechancay.com
SOCKETIO_CORS_ALLOWED_ORIGINS=

# Solo usar si en el futuro escalas Socket.IO con Redis y múltiples nodos
SOCKETIO_MESSAGE_QUEUE=
